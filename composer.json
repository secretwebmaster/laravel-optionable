{
    "name": "secretwebmaster/laravel-optionable",
    "description": "Allow any Eloquent model to have own options such as user options, page options, etc.",
    "keywords": [
        "laravel",
        "eloquent",
        "options",
        "settings",
        "preferences",
        "wncms",
        "secretwebmaster"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/secretwebmaster/laravel-optionable",
    "support": {
        "issues": "https://github.com/secretwebmaster/laravel-optionable/issues",
        "source": "https://github.com/secretwebmaster/laravel-optionable"
    },
    "autoload": {
        "psr-4": {
            "Secretwebmaster\\LaravelOptionable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Secretwebmaster\\LaravelOptionable\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "authors": [
        {
            "name": "secretwebmaster",
            "email": "earnbyshare2016@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "secretwebmaster/wncms-translatable": "^1.3.2 || dev-main as 1.4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.5"
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve"
        ],
        "lint": [
            "@php vendor/bin/phpstan analyse"
        ],
        "test": [
            "@php vendor/bin/phpunit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Secretwebmaster\\LaravelOptionable\\Providers\\PackageServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "2.1.x-dev"
        }
    }
}
